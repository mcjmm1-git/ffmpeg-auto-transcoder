###############################################################################
# USER
###############################################################################

# User and group that will own the generated files.
#
# Obtain them with:
#
#   id -u
#   id -g
#

PUID=1000
PGID=1000

###############################################################################
# MEDIA LIBRARY
###############################################################################

# Path to your media library on the host.
#
# Example:
#
#   /mnt/media
#   /srv/movies
#   /home/user/Videos
#

HOST_MEDIA=

###############################################################################
# API KEYS
###############################################################################

# Enter your own TMDB API key.
#
# https://www.themoviedb.org/settings/api
#

TMDB_API_KEY=

# Enter your own OMDb API key.
#
# https://www.omdbapi.com/apikey.aspx
#

OMDB_API_KEY=
